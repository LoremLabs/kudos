{
  "name": "@kudos-protocol/storage-postgres",
  "version": "0.0.3",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
