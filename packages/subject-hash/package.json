{
	"name": "@kudos-protocol/subject-hash",
	"version": "1.0.3",
	"description": "A library for generating a Subject-Hash from a subject",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"subject-hash": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && chmod +x dist/cli.js",
		"pretty": "prettier --check .",
		"format": "prettier --write . && eslint --fix --ignore-path .gitignore .",
		"pretty:fix": "prettier --write .",
		"lint": "eslint --ignore-path .gitignore .",
		"lint:fix": "prettier --write . && eslint --fix --ignore-path .gitignore .",
		"prepublishOnly": "npm run build",
		"release": "npm publish --access public",
		"test": "tsc && node --test dist/index.test.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LoremLabs/kudos.git#main"
	},
	"keywords": [
		"kudos",
		"subject-hash",
		"ident-agency"
	],
	"author": "@loremlabs",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/LoremLabs/kudos/issues"
	},
	"homepage": "https://github.com/LoremLabs/kudos/tree/main/core/subject-hash#readme",
	"devDependencies": {
		"eslint": "^8.39.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-prettier": "^4.2.1",
		"@types/node": "^20.0.0",
		"prettier": "^2.8.8",
		"typescript": "^5.4.0"
	},
	"packageManager": "pnpm@10.6.3+sha512.bb45e34d50a9a76e858a95837301bfb6bd6d35aea2c5d52094fa497a467c43f5c440103ce2511e9e0a2f89c3d6071baac3358fc68ac6fb75e2ceb3d2736065e6"
}
